# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/unified_fintech

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ADMIN_SECRET_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── SMS — Infobip ─────────────────────────────────────────────────────────────
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_SENDER_ID=FinTechApp

# ── KYC — Cloudinary ──────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── KYC — OCR + Face++ ───────────────────────────────────────────────────────
OCR_API_KEY=
FACE_API_KEY=
FACE_API_SECRET=

# ── FIREBASE FCM ──────────────────────────────────────────────────────────────
# Option A: path to JSON file (local dev)
FIREBASE_CREDENTIALS_JSON=
# Option B: base64-encoded JSON (Railway — preferred)
FIREBASE_CREDENTIALS_BASE64=

# ── APP CONFIG ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
DEV_MODE=true
